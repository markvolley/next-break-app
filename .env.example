# Copy this file to .env and fill in your own values.
# Get test keys from https://dashboard.stripe.com/test/apikeys — no live
# business details needed to test in Stripe's sandbox mode.

STRIPE_SECRET_KEY=sk_test_...

# Optional — only needed if you set up `stripe listen` for webhooks (see README).
STRIPE_WEBHOOK_SECRET=

# Optional overrides
PORT=3000
UNLOCK_FEE_CENTS=500

# Real flight prices (Travelpayouts/Aviasales). Sign up free at
# https://www.travelpayouts.com, then grab your API token from
# https://www.travelpayouts.com/programs/100/tools/api
TRAVELPAYOUTS_TOKEN=

# Your affiliate marker (public tracking ID) — earns you commission on
# bookings made through your links. Find it in your Travelpayouts dashboard.
TRAVELPAYOUTS_MARKER=

# Real "things to do" activities (Viator, owned by TripAdvisor). Sign up
# free at https://partners.viator.com/signup, then find your credentials
# under Tools > Affiliate API in your partner dashboard.
VIATOR_API_KEY=
VIATOR_PID=
VIATOR_MCID=

# Real ticketed events (concerts, sport, theatre) near a user's hometown
# during each break, via Ticketmaster's Discovery API. Free, self-serve, no
# approval wait — sign up at https://developer.ticketmaster.com, create an
# app, and grab the "Consumer Key" from its Keys tab (that's this value —
# the Consumer Secret isn't needed). Leave blank to hide the events section
# entirely.
TICKETMASTER_API_KEY=

# To earn commission on Ticketmaster bookings: apply for Ticketmaster's
# Affiliate Program via Impact —
# https://developer.ticketmaster.com/partners/distribution-partners/affiliate-sign-up/
# (separate approval step from the API key above, can take a few days).
# Once approved, you get an Impact Publisher ID — enter THAT in the
# Ticketmaster developer portal itself (My Apps -> your app -> Affiliate
# IDs -> "Profile Edit"), not here. Once linked there, event links from the
# API come back commission-tracked automatically — nothing to set in this
# file for the normal path.
#
# TICKETMASTER_AFFILIATE_LINK_PREFIX below is only for the unusual case
# where you'd rather route through a different tracking link than
# Ticketmaster's own auto-tracking — leave it blank unless you have a
# specific reason not to use the Profile Edit method above. If set, it
# should be an Impact-style deep-link base ending in "?u=" (see
# buildEventUrl in lib/ticketmaster.js for the exact format).
TICKETMASTER_AFFILIATE_LINK_PREFIX=

# Google Sign-In. Not secret — it's a public client ID meant to be embedded
# in frontend JS, same category as a Stripe *publishable* key. Get one free
# at https://console.cloud.google.com/apis/credentials (create an OAuth
# 2.0 Client ID, type "Web application"). Leave blank to hide the Google
# button and only offer email/password login.
GOOGLE_CLIENT_ID=

# Password-reset emails, sent via Resend (https://resend.com — free tier,
# sign up free, no credit card required). Grab your API key from
# https://resend.com/api-keys. RESEND_API_KEY is secret. Without it, reset
# links are just logged to the server console instead of emailed — fine for
# local testing, not for production.
RESEND_API_KEY=

# The "from" address on reset emails. Must be a sender/domain verified in
# your Resend account — https://resend.com/domains. Leave as-is to use
# Resend's shared onboarding@resend.dev sender, which works without domain
# verification but is best for testing only, not production sending.
EMAIL_FROM=Next Break <onboarding@resend.dev>

# Admin dashboard (/admin.html) — shows signup counts, marketing opt-ins,
# and deal-click stats. Only the account(s) whose email is listed here can
# load it; anyone else gets a 403. Comma-separate multiple emails if needed.
# Log in as this email on the site first, then visit /admin.html.
ADMIN_EMAIL=mark.volley@gmail.com
